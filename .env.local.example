# Copy to .env.local and fill in. Never commit .env.local.
# Values map 1:1 to PRD § Technical Architecture > Required Environment Variables.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, never expose to the client

# --- AI classification ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5   # classification model; swap to upgrade quality
CAPTURE_TZ=Europe/Berlin           # user timezone for resolving relative due dates

# --- Push notifications (ntfy) ---
NTFY_TOPIC_URL=                   # e.g. https://ntfy.sh/atlas-dom-<random>

# --- Google Calendar (read-only) ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# --- Capture token hashing ---
CAPTURE_PEPPER=                   # used to hash iOS-Shortcut API tokens

# --- Cron authentication ---
CRON_SECRET=                     # shared secret for /api/cron/* — the GitHub Actions
                                 # scheduler and manual curls send it as
                                 # `Authorization: Bearer <CRON_SECRET>`
